#!jinja2

{% set HPC_HOST = HPC_HOST if HPC_HOST is defined else HPC_HOST %}
{% set HPC_HOST = DEPLOYMENT_HOST if DEPLOYMENT_HOST is defined else HPC_HOST %}


[scheduler]
    UTC mode = True
    install = src/, file/
    [[events]]
        stall timeout handlers = "rose suite-hook --shutdown"

[scheduling] 
    [[graph]]
	 R1 = """
         prepare_hpc_host => extract_xios_background => build_xios => create_xios_module => create_prgenv_module => run_xios_toy_attached & run_xios_toy_server
{% if not XIOS_ONLY %}
                prepare_hpc_host => extract_oasis => build_oasis => run_oasis_tutorial => create_oasis_module => build_xios
{% endif %}
                """
[runtime]
    [[root]]
        script = 'rose task-run --verbose'
    [[LINUX_SERVER]]
        execution time limit = PT15M
	platform = slurm
        [[[directives]]]
            --ntasks=1
            --mem=1G
            --qos=normal
    [[LOCALHOST]]
        platform=localhost
    [[HPC]]
	env-script = "{{MODULE_CMD}}; export LD_LIBRARY_PATH=/opt/cray/pe/pmi/6.1.11/lib:$LD_LIBRARY_PATH; echo $LD_LIBRARY_PATH"
	platform = {{HPC_HOST}}
    [[HPC_SERIAL]]
        inherit = None, HPC
	execution time limit = PT10M
        [[[environment]]]
            ROSE_TASK_N_JOBS = 1
        [[[directives]]]
            -l select=1:ncpus=1
            -q = shared
        [[prepare_hpc_host]]
            inherit = HPC_SERIAL
	    script = 'echo Preparing HPC for file transfer'
{% if not XIOS_ONLY %}
    [[OASIS]]
        [[[environment]]]
	    PRISMPATH=$CYLC_SUITE_RUN_DIR/share/oasis3-mct
    [[extract_oasis]]
        inherit=LOCALHOST
        env-script = """
		     eval $(rose task-env);
		     export OASIS_BUILD_DIR="~/cylc-run/$ROSE_SUITE_NAME/share"
		     """
		   
        [[[directives]]]
            --mem=8G
        [[[environment]]]
            HPC_HOST_USERNAME={{HPC_HOST_USERNAME}}
            HPC_HOST={{HPC_HOST}}
	    EXTRACT_OASIS={{EXTRACT_OASIS}}
{% if EXTRACT_OASIS == true %}
	    OASIS_BRANCH={{OASIS_BRANCH}}
	    OASIS_REPOSITORY={{OASIS_REPOSITORY}}
{% else %}
            OASIS_WC_DIR={{OASIS_WC_DIR}}
{% endif %}
    [[build_oasis]]
        inherit = None, HPC_SERIAL, OASIS
	execution time limit = PT20M
        [[[environment]]]
	    BUILD_MCT={{BUILD_MCT}}
	    BUILD_TEST={{BUILD_TEST}}
	    OASIS_BUILD_DIR={{OASIS_BUILD_DIR}}
	    PLATFORM_CONFIG={{PLATFORM_CONFIG}}
    [[run_oasis_tutorial]]
        inherit = None, HPC, OASIS
        [[[directives]]]
            -l walltime = 00:10:00
	    -l select=1:ncpus=256:mpiprocs=3+1:ncpus=256:mpiprocs=3
        [[[environment]]]
	    TEST_MODEL1_EXE=model1
	    TEST_MODEL2_EXE=model2
	    NPROC_EXE1=3
	    NPROC_EXE2=3
    [[create_oasis_module]]
        inherit = None, HPC_SERIAL, OASIS
	[[[environment]]]
{% if OASIS_BRANCH is defined %}
	    OASIS_BRANCH={{OASIS_BRANCH}}
{% else %}
            OASIS_BRANCH=working_copy
{% endif %}
{% if OASIS_REPOSITORY is defined %}
	    OASIS_REPOSITORY={{OASIS_REPOSITORY}}
{% else %}
            OASIS_REPOSITORY=working_copy
{% endif %}
	    OASIS_MOD_NAME={{OASIS_MOD_NAME}}
	    OASIS_MOD_VERSION={{OASIS_MOD_VERSION}}
	    OASIS_BUILD_DIR={{OASIS_BUILD_DIR}}
{% if SUITE_URL is defined %}
      	    SUITE_URL={{SUITE_URL}}
{% endif %}
{% if SUITE_REVISION is defined %}
            SUITE_REVISION={{SUITE_REVISION}}
{% endif %}
{% if MODULE_BASE is defined %}
            MODULE_BASE={{MODULE_BASE}}
{% endif %}
#end not XIOS only
{% endif %}
    [[XIOS]]
        [[[environment]]]
            XIOSPATH=$CYLC_SUITE_RUN_DIR/share/xios
    [[extract_xios_background]]
{% if XIOS_GIT == true %}
        inherit = XIOS, LOCALHOST
        script='rose task-run --verbose --command-key=git'
        [[[environment]]]
	    HPC_HOST={{HPC_HOST}}
	    ROSE_TASK_APP=extract_xios
	    XIOS_GIT_REPOSITORY={{XIOS_GIT_REPOSITORY}}
	    XIOS_HASH={{XIOS_HASH}}
{% else %}
        inherit = XIOS, HPC_SERIAL
        [[[environment]]]
            ROSE_TASK_APP=extract_xios
            XIOS_VERSION={{XIOS_VERSION}}
	    XIOS_REV={{XIOS_REV}}
	    XIOS_URL={{XIOS_URL}}
{% endif %}
    [[build_xios]]
        inherit = None, HPC, XIOS
	execution time limit = PT2H
	env-script = """
		     {{MODULE_CMD}};
{% if not XIOS_ONLY %}
		     eval $(cat $CYLC_SUITE_RUN_DIR/share/use_oasis_mod.sh);
		     module use $OASIS_MODULE_USE_PATH;
		     module load $OASIS_MODULE_PATH;
{% endif %}
		     module list;
		     """
        [[[environment]]]
            XIOS_ONLY={{XIOS_ONLY}}
	[[[directives]]]
	    -l select=1:ncpus=8
    [[create_xios_module]]
        inherit = None, HPC_SERIAL, XIOS
	[[[environment]]]
{% if XIOS_GIT == true %}
            XIOS_URL={{XIOS_GIT_REPOSITORY}}
            XIOS_REV={{XIOS_HASH}}
	    XIOS_VERSION=""
{% else %}
            XIOS_URL={{XIOS_URL}}
            XIOS_REV={{XIOS_REV}}
	    XIOS_VERSION={{XIOS_VERSION}}
{% endif %}
	    XIOS_MOD_VERSION={{XIOS_MOD_VERSION}}
	    XIOS_MOD_NAME={{XIOS_MOD_NAME}}
{% if SUITE_URL is defined %}
      	    SUITE_URL={{SUITE_URL}}
{% endif %}
{% if SUITE_REVISION is defined %}
            SUITE_REVISION={{SUITE_REVISION}}
{% endif %}
{% if MODULE_BASE is defined %}
            MODULE_BASE={{MODULE_BASE}}
{% endif %}
    [[RUN_XIOS_TOY]]
        env-script = """
                     {{MODULE_CMD}};
                     eval $(cat $CYLC_SUITE_RUN_DIR/share/load_prgenv_mod.sh);
                     module use $TEST_PRGENV_MODULE_PATH
                     module load $TEST_PRGENV_MODULE_NAME
                     module list
                     """
        [[[environment]]]
            ROSE_TASK_APP=xios_toy
            XIOS_ONLY={{XIOS_ONLY}}
    [[run_xios_toy_attached]]
        inherit = RUN_XIOS_TOY, HPC_SERIAL
        [[[environment]]]
            XIOS_TEST_MODE=attached
    [[run_xios_toy_server]]
        inherit = RUN_XIOS_TOY, HPC
	[[[directives]]]
	    -l walltime = 00:10:00
	    -l select=1:ncpus=256:mpiprocs=1+1:ncpus=256:mpiprocs=1
        [[[environment]]]
            XIOS_TEST_MODE=server
    [[create_prgenv_module]]
        inherit = None, HPC_SERIAL
	env-script = """
		     {{MODULE_CMD}}; export LD_LIBRARY_PATH=/opt/cray/pe/pmi/6.1.11/lib:$LD_LIBRARY_PATH;
{% if not XIOS_ONLY %}
		     eval $(cat $CYLC_SUITE_RUN_DIR/share/use_oasis_mod.sh);
{% endif %}
		     eval $(cat $CYLC_SUITE_RUN_DIR/share/use_xios_mod.sh);
		     """
        [[[environment]]]
            XIOS_ONLY={{XIOS_ONLY}}
	    MODULE_STR={{MODULE_CMD}}
{% if not XIOS_ONLY %}
	    PRG_ENV_VERSION={{GC_PRG_ENV_VERSION}}
	    PRG_ENV_NAME={{GC_PRG_ENV_NAME}}
{% else %}
            PRG_ENV_VERSION={{XIOS_PRG_ENV_VERSION}}
	    PRG_ENV_NAME={{XIOS_PRG_ENV_NAME}}
{% endif %} 
{% if SUITE_URL is defined %}
      	    SUITE_URL={{SUITE_URL}}
{% endif %}
{% if SUITE_REVISION is defined %}
            SUITE_REVISION={{SUITE_REVISION}}
{% endif %}
{% if MODULE_BASE is defined %}
            MODULE_BASE={{MODULE_BASE}}
{% endif %}
